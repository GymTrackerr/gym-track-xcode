    "progression.builtIn.doubleProgression.description": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Build reps inside a range before moving the weight up."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Build reps inside a range before moving the weight up."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Augmentez les répétitions dans une plage avant d’augmenter la charge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aumenta las repeticiones dentro de un rango antes de subir el peso."
          }
        }
      }
    },
    "progression.builtIn.linear.description": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Increase the load by a small amount after a successful session."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Increase the load by a small amount after a successful session."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Augmentez légèrement la charge après une séance réussie."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aumenta un poco la carga después de una sesión exitosa."
          }
        }
      }
    },
    "progression.builtIn.volume.description": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Add more sets over time while keeping reps steady."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Add more sets over time while keeping reps steady."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez progressivement des séries tout en gardant les répétitions stables."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade más series con el tiempo manteniendo las repeticiones estables."
          }
        }
