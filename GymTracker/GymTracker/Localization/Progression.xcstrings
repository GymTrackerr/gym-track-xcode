    "progression.exerciseOverride.automaticSourceDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is currently handling this exercise. Saving here will turn this into an exercise-only override."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ is currently handling this exercise. Saving here will turn this into an exercise-only override."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ gère actuellement cet exercice. En enregistrant ici, vous créerez un remplacement propre à cet exercice."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ está gestionando este ejercicio. Al guardar aquí, se convertirá en un ajuste solo para este ejercicio."
          }
        }
      },
      "comment": "Explains that an inherited progression source will be replaced by an exercise override"
    },
    "progression.exerciseOverride.emptyDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Set an exercise-only override. If you leave this empty, routine, programme, or global defaults can still apply automatically."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Set an exercise-only override. If you leave this empty, routine, program, or global defaults can still apply automatically."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Définissez un remplacement propre à cet exercice. Si vous le laissez vide, les valeurs par défaut de routine, de programme ou globales peuvent toujours s’appliquer automatiquement."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura un ajuste solo para este ejercicio. Si lo dejas vacío, los valores de rutina, programa o globales podrán aplicarse automáticamente."
          }
        }
      }
    },
    "progression.exerciseOverride.noOverride": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "No exercise override yet. Routine, programme, or global defaults can still apply automatically when you start logging."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "No exercise override yet. Routine, program, or global defaults can still apply automatically when you start logging."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun remplacement d’exercice pour le moment. Les valeurs par défaut de routine, de programme ou globales peuvent toujours s’appliquer automatiquement quand vous commencez à enregistrer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no hay ajuste para este ejercicio. Los valores de rutina, programa o globales podrán aplicarse automáticamente cuando empieces a registrar."
          }
        }
      }
    },
