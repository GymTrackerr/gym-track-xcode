    "progression.profiles.automatic.orderDescription": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Session source still wins first: exercise override, then programme default, then routine default, and this global default fills the gaps."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Session source still wins first: exercise override, then program default, then routine default, and this global default fills the gaps."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La source de la séance reste prioritaire : remplacement de l’exercice, puis valeur par défaut du programme, puis de la routine, et cette valeur globale complète le reste."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La fuente de la sesión sigue teniendo prioridad: ajuste del ejercicio, luego predeterminado del programa, luego de la rutina, y este valor global cubre lo restante."
          }
        }
      }
    },
    "progression.profiles.automatic.subtitle": {
      "localizations": {
        "en-GB": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable this if you want every routine-less exercise to fall back to one default profile when no exercise, routine, or programme override is set."
          }
        },
        "en-US": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable this if you want every routine-less exercise to fall back to one default profile when no exercise, routine, or program override is set."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez ceci pour que chaque exercice sans routine utilise un profil par défaut lorsqu’aucun remplacement d’exercice, de routine ou de programme n’est défini."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actívalo si quieres que cada ejercicio sin rutina use un perfil predeterminado cuando no haya ajuste de ejercicio, rutina o programa."
          }
        }
      }
    },
