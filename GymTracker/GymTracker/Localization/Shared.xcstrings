    "Health-backed cards like weight, steps, sleep, activity rings, and imported workouts will stay visible here once access is enabled in Settings." : {
      "localizations" : {
        "en-GB" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health-backed cards like weight, steps, sleep, activity rings, and imported workouts will stay visible here once access is enabled in Settings."
          }
        },
        "en-US" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Health-backed cards like weight, steps, sleep, activity rings, and imported workouts will stay visible here once access is enabled in Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las tarjetas basadas en salud, como peso, pasos, sueño, anillos de actividad y entrenamientos importados, aparecerán aquí cuando actives el acceso en Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
